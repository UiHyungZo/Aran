default_platform(:ios)

platform :ios do
  desc "Run lint and unit tests used by CI"
  lane :ci do
    ensure_secrets_xcconfig
    lint
    domain_tests
    unit_tests
  end

  desc "Run SwiftLint"
  lane :lint do
    sh("swiftlint lint --reporter github-actions-logging")
  end

  desc "Run Domain package tests"
  lane :domain_tests do
    sh("swift test --package-path Packages/AranDomain")
  end

  desc "Run Xcode unit tests"
  lane :unit_tests do
    scan(
      project: "Aran.xcodeproj",
      scheme: "AranTests",
      device: "iPhone 16 Pro",
      result_bundle: true,
      output_directory: "fastlane/test_output"
    )
  end

  desc "Archive and upload a build to TestFlight"
  lane :beta do
    ci
    setup_app_store_connect_api_key
    increment_build_number(
      build_number: latest_testflight_build_number(initial_build_number: 0) + 1,
      xcodeproj: "Aran.xcodeproj"
    )
    build_app_store_archive
    upload_to_testflight(skip_waiting_for_build_processing: true)
  end

  desc "Archive and upload a build to App Store Connect without submitting for review"
  lane :release do
    ci
    setup_app_store_connect_api_key
    build_app_store_archive
    upload_to_app_store(
      submit_for_review: false,
      automatic_release: false,
      skip_metadata: true,
      skip_screenshots: true,
      force: true
    )
  end

  private_lane :build_app_store_archive do
    provisioning_profile_name = ENV.fetch("PROVISIONING_PROFILE_SPECIFIER")

    gym(
      project: "Aran.xcodeproj",
      scheme: "Aran",
      configuration: "Release",
      export_method: "app-store",
      output_directory: "fastlane/build",
      output_name: "Aran.ipa",
      export_options: {
        provisioningProfiles: {
          "com.www.Aran" => provisioning_profile_name
        }
      },
      xcargs: [
        "DEVELOPMENT_TEAM=9G5T5K3BP2",
        "CODE_SIGN_STYLE=Manual",
        "CODE_SIGNING_REQUIRED=YES",
        "PROVISIONING_PROFILE_SPECIFIER='#{provisioning_profile_name}'"
      ].join(" ")
    )
  end

  private_lane :setup_app_store_connect_api_key do
    app_store_connect_api_key(
      key_id: ENV.fetch("ASC_API_KEY_ID"),
      issuer_id: ENV.fetch("ASC_API_KEY_ISSUER_ID"),
      key_content: ENV.fetch("ASC_API_KEY_CONTENT"),
      is_key_content_base64: true,
      in_house: false
    )
  end

  private_lane :ensure_secrets_xcconfig do
    next if ENV["CI"]

    secrets_path = "Aran/Configuration/Secrets.xcconfig"
    example_path = "Aran/Configuration/Secrets.xcconfig.example"

    sh("cp #{example_path} #{secrets_path}") unless File.exist?(secrets_path)
  end
end
