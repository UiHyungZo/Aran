require "fileutils"
require "shellwords"

REPO_ROOT = File.expand_path("..", __dir__)

def repo_path(*components)
  File.join(REPO_ROOT, *components)
end

default_platform(:ios)

platform :ios do
  desc "Run lint and unit tests used by CI"
  lane :ci do
    ensure_secrets_xcconfig
    lint
    domain_tests
    unit_tests
  end

  desc "Run SwiftLint"
  lane :lint do
    sh("swiftlint lint --reporter github-actions-logging #{REPO_ROOT.shellescape}")
  end

  desc "Run Domain package tests"
  lane :domain_tests do
    sh("swift test --package-path #{repo_path("Packages/AranDomain").shellescape}")
  end

  desc "Run Xcode unit tests"
  lane :unit_tests do
    result_bundle_path = repo_path("fastlane/test-results/AranTests.xcresult")
    FileUtils.rm_rf(result_bundle_path)
    FileUtils.mkdir_p(File.dirname(result_bundle_path))

    sh("set -o pipefail && xcodebuild test " \
       "-project #{repo_path("Aran.xcodeproj").shellescape} " \
       "-scheme AranTests " \
       "-destination 'platform=iOS Simulator,name=iPhone 16 Pro' " \
       "-resultBundlePath #{result_bundle_path.shellescape}")
  end

  desc "Archive and upload a build to TestFlight"
  lane :beta do
    ci
    setup_app_store_connect_api_key
    increment_build_number(
      build_number: latest_testflight_build_number(initial_build_number: 0) + 1,
      xcodeproj: repo_path("Aran.xcodeproj")
    )
    build_app_store_archive
    upload_to_testflight(skip_waiting_for_build_processing: true)
  end

  desc "Archive and upload a build to App Store Connect without submitting for review"
  lane :release do
    ci
    setup_app_store_connect_api_key
    build_app_store_archive
    upload_to_app_store(
      submit_for_review: false,
      automatic_release: false,
      skip_metadata: true,
      skip_screenshots: true,
      force: true
    )
  end

  private_lane :build_app_store_archive do
    provisioning_profile_name = ENV.fetch("PROVISIONING_PROFILE_SPECIFIER")

    update_code_signing_settings(
      use_automatic_signing: false,
      path: repo_path("Aran.xcodeproj"),
      team_id: "9G5T5K3BP2",
      targets: ["Aran"],
      code_sign_identity: "Apple Distribution",
      profile_name: provisioning_profile_name,
      bundle_identifier: "com.www.Aran"
    )

    gym(
      project: repo_path("Aran.xcodeproj"),
      scheme: "Aran",
      configuration: "Release",
      export_method: "app-store",
      output_directory: repo_path("fastlane/build"),
      output_name: "Aran.ipa",
      export_options: {
        signingStyle: "manual",
        provisioningProfiles: {
          "com.www.Aran" => provisioning_profile_name
        }
      }
    )
  end

  private_lane :setup_app_store_connect_api_key do
    app_store_connect_api_key(
      key_id: ENV.fetch("ASC_API_KEY_ID"),
      issuer_id: ENV.fetch("ASC_API_KEY_ISSUER_ID"),
      key_content: ENV.fetch("ASC_API_KEY_CONTENT"),
      is_key_content_base64: true,
      in_house: false
    )
  end

  private_lane :ensure_secrets_xcconfig do
    next if ENV["CI"]

    secrets_path = repo_path("Aran/Configuration/Secrets.xcconfig")
    example_path = repo_path("Aran/Configuration/Secrets.xcconfig.example")

    FileUtils.cp(example_path, secrets_path) unless File.exist?(secrets_path)
  end
end
